#!/bin/bash
# Install packages on the builder machine that are required to build the LFS system.

declare -a DEPS=(
    "sort"
    "bash"
    "ld"
    "bison"
    "utils"  # provides the diff tool
    "find"
    "gawk"
    "gcc"
    "g++"
    "grep"
    "gzip"
    "m4"
    "make"
    "patch"
    "perl"
    "python3"
    "sed"
    "tar"
    "texi2any"
    "xz"
)

sudo apt-get install -y "${DEPS[@]}"



